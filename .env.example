# PostgreSQL (primary — odg database)
PG_HOST=
PG_PORT=5432
PG_DATABASE=odg
PG_USER=postgres
PG_PASSWORD=

# PostgreSQL (secondary — odservice database)
PG_HOST_B=
PG_PORT_B=5432
PG_DATABASE_B=odservice
