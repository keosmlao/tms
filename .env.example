PG_PASSWORD_B=

# JWT Secret (generate a strong random string, e.g. `openssl rand -base64 32`)
JWT_SECRET=

# Thai GPS Tracker
GPS_TRACKER_API_URL=https://apis.thaigpstracker.co.th
GPS_TRACKER_USER=
GPS_TRACKER_PASS=

# LINE Notify (optional)
LINE_NOTIFY_TOKEN=
LINE_ACCESS_TOKEN=
